# ===========================
# Report Service - Dev Local
# ===========================
# Shared PostgreSQL (ng_fields DB, schema: reports)

# --- Spring ---
SPRING_PROFILES_ACTIVE=dev
ENV_FILE=./.env
CORS_ORIGINS=http://localhost:4200,http://localhost:8100
